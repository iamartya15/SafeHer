{
  "name": "safeher-ai-root",
  "version": "1.0.0",
  "description": "Root orchestrator for SafeHer AI",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend --legacy-peer-deps",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --prefix frontend",
    "start:backend": "npm start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
