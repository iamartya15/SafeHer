# SafeHer AI - Environment Configuration Example
# Copy this file to a new file named '.env' in the same directory and fill in your values.

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (Append safeher database if not present in string)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/safeher?retryWrites=true&w=majority

# JWT Token Security (Change in production to strong unique strings)
JWT_SECRET=super_secret_access_token_key_123456789_safeher_ai
JWT_REFRESH_SECRET=super_secret_refresh_token_key_987654321_safeher_ai

# Google Gemini API Key (Optional, will fall back to local rule-based responses if missing)
GEMINI_API_KEY=your_google_gemini_api_key_here
# Google Gemini Model (Optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-3.5-flash

# Cloudinary Storage Configuration (Optional, will fall back to public/uploads directory if missing)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Email Settings (Optional, will log links to console if mock values or missing)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_safeher_support_email@gmail.com
EMAIL_PASS=your_email_app_password_here

# Client URL (Must match the URL where the React application is running)
FRONTEND_URL=http://localhost:5173
